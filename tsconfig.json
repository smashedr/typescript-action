{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "module": "NodeNext",
    "target": "ESNext",
    "resolveJsonModule": true,
    "removeComments": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src"]
}
